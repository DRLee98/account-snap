# 옵션 A. CLOVA OCR 직접 호출 (개발/초기 출시용 — 키가 바이너리에 박힘)
CLOVA_INVOKE_URL=https://xxxxx.apigw.ntruss.com/custom/v1/.../general
CLOVA_SECRET_KEY=your-secret-key-here

# 옵션 B. Proxy 사용 (출시 후 권장 — 키는 proxy에만 보관)
# OCR_PROXY_URL이 비어있지 않으면 옵션 A 무시하고 proxy로 호출.
# OCR_PROXY_TOKEN은 선택 — proxy 측에서 X-Proxy-Token 헤더로 1차 abuse 차단할 때만.
# OCR_PROXY_URL=https://your-worker.example.workers.dev/ocr
# OCR_PROXY_TOKEN=
